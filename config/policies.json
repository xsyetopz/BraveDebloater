{
  "schemaVersion": 1,
  "policyTemplateVersion": "148.1.91.121",
  "sources": [
    "https://support.brave.app/hc/en-us/articles/360039248271-Group-Policy",
    "https://brave-browser-downloads.s3.brave.com/latest/policy_templates.zip"
  ],
  "safety": {
    "blockedPolicyNames": [
      "BraveShieldsDisabledForUrls",
      "SafeBrowsingAllowlistDomains",
      "SSLErrorOverrideAllowed",
      "SSLErrorOverrideAllowedForOrigins",
      "DisableSafeBrowsingProceedAnyway",
      "HttpsOnlyMode",
      "ComponentUpdatesEnabled",
      "BraveSyncUrl"
    ],
    "blockedNamePatterns": [
      ".*ShieldsDisabled.*",
      ".*SafeBrowsing.*Allowlist.*",
      ".*Update.*Disabled.*"
    ]
  },
  "presets": {
    "Standard": [
      "@Core"
    ],
    "High": [
      "@Privacy"
    ],
    "Extreme": [
      "@Aggressive"
    ],
    "Core": [
      "BraveRewardsDisabled",
      "BraveWalletDisabled",
      "BraveVPNDisabled",
      "BraveAIChatEnabled",
      "BraveNewsDisabled",
      "BraveTalkDisabled",
      "BravePlaylistEnabled",
      "BraveSpeedreaderEnabled",
      "BraveWaybackMachineEnabled",
      "BraveP3AEnabled",
      "BraveStatsPingEnabled",
      "BraveWebDiscoveryEnabled"
    ],
    "Privacy": [
      "@Core",
      "BraveDeAmpEnabled",
      "BraveDebouncingEnabled",
      "BraveGlobalPrivacyControlEnabled",
      "BraveTrackingQueryParametersFilteringEnabled",
      "BraveReduceLanguageEnabled",
      "MetricsReportingEnabled",
      "UrlKeyedAnonymizedDataCollectionEnabled",
      "PrivacySandboxPromptEnabled",
      "SearchSuggestEnabled",
      "NetworkPredictionOptions",
      "SpellCheckServiceEnabled"
    ],
    "Aggressive": [
      "@Privacy",
      "BackgroundModeEnabled",
      "PromotionsEnabled",
      "BrowserLabsEnabled",
      "MediaRecommendationsEnabled",
      "NTPCardsVisible",
      "ShoppingListEnabled",
      "QRCodeGeneratorEnabled",
      "PaymentMethodQueryEnabled",
      "AutofillCreditCardEnabled",
      "AutofillAddressEnabled",
      "TranslateEnabled",
      "LiveTranslateEnabled",
      "GoogleSearchSidePanelEnabled"
    ],
    "ShieldBaseline": [
      "DefaultBraveAdblockSetting",
      "DefaultBraveFingerprintingV2Setting",
      "DefaultBraveHttpsUpgradeSetting",
      "DefaultBraveReferrersSetting"
    ]
  },
  "features": [
    {
      "id": "Rewards",
      "label": "Brave Rewards",
      "policies": [
        "BraveRewardsDisabled"
      ],
      "reason": "Remove Rewards, BAT prompts, and rewards ads."
    },
    {
      "id": "Wallet",
      "label": "Brave Wallet",
      "policies": [
        "BraveWalletDisabled"
      ],
      "reason": "Remove Brave Wallet and Web3 entry points."
    },
    {
      "id": "VPN",
      "label": "Brave VPN",
      "policies": [
        "BraveVPNDisabled"
      ],
      "reason": "Remove Brave VPN buttons and subscription prompts."
    },
    {
      "id": "LeoAI",
      "label": "Leo AI Chat",
      "policies": [
        "BraveAIChatEnabled"
      ],
      "reason": "Disable Leo AI chat integrations."
    },
    {
      "id": "News",
      "label": "Brave News",
      "policies": [
        "BraveNewsDisabled"
      ],
      "reason": "Remove Brave News surfaces."
    },
    {
      "id": "Talk",
      "label": "Brave Talk",
      "policies": [
        "BraveTalkDisabled"
      ],
      "reason": "Remove Brave Talk widgets and meeting entry points."
    },
    {
      "id": "Playlist",
      "label": "Brave Playlist",
      "policies": [
        "BravePlaylistEnabled"
      ],
      "reason": "Disable Brave Playlist."
    },
    {
      "id": "Speedreader",
      "label": "Speedreader",
      "policies": [
        "BraveSpeedreaderEnabled"
      ],
      "reason": "Disable Speedreader suggestions."
    },
    {
      "id": "Wayback",
      "label": "Wayback prompts",
      "policies": [
        "BraveWaybackMachineEnabled"
      ],
      "reason": "Disable Wayback Machine prompts on missing pages."
    },
    {
      "id": "BraveTelemetry",
      "label": "Brave telemetry",
      "policies": [
        "BraveP3AEnabled",
        "BraveStatsPingEnabled",
        "BraveWebDiscoveryEnabled"
      ],
      "reason": "Disable Brave analytics, stats pings, and Web Discovery contributions."
    },
    {
      "id": "DeAmp",
      "label": "De-AMP",
      "policies": [
        "BraveDeAmpEnabled"
      ],
      "reason": "Keep AMP redirects to publisher pages enabled."
    },
    {
      "id": "Debouncing",
      "label": "bounce tracking debouncing",
      "policies": [
        "BraveDebouncingEnabled"
      ],
      "reason": "Keep bounce tracking debouncing enabled."
    },
    {
      "id": "GlobalPrivacyControl",
      "label": "Global Privacy Control",
      "policies": [
        "BraveGlobalPrivacyControlEnabled"
      ],
      "reason": "Send Global Privacy Control signals."
    },
    {
      "id": "TrackingQueryFiltering",
      "label": "tracking query filtering",
      "policies": [
        "BraveTrackingQueryParametersFilteringEnabled"
      ],
      "reason": "Strip known tracking query parameters."
    },
    {
      "id": "ReduceLanguage",
      "label": "language fingerprint reduction",
      "policies": [
        "BraveReduceLanguageEnabled"
      ],
      "reason": "Reduce language fingerprinting surface."
    },
    {
      "id": "ChromiumTelemetry",
      "label": "Chromium telemetry",
      "policies": [
        "MetricsReportingEnabled",
        "UrlKeyedAnonymizedDataCollectionEnabled"
      ],
      "reason": "Disable Chromium metrics and URL-keyed collection."
    },
    {
      "id": "PrivacySandboxPrompt",
      "label": "Privacy Sandbox prompts",
      "policies": [
        "PrivacySandboxPromptEnabled"
      ],
      "reason": "Disable Privacy Sandbox prompts."
    },
    {
      "id": "SearchSuggestions",
      "label": "remote search suggestions",
      "policies": [
        "SearchSuggestEnabled"
      ],
      "reason": "Disable remote address bar search suggestions."
    },
    {
      "id": "NetworkPrediction",
      "label": "network prediction",
      "policies": [
        "NetworkPredictionOptions"
      ],
      "reason": "Disable network prediction and preconnect."
    },
    {
      "id": "RemoteSpellcheck",
      "label": "remote spellcheck",
      "policies": [
        "SpellCheckServiceEnabled"
      ],
      "reason": "Disable remote spellcheck while keeping local spellcheck untouched."
    },
    {
      "id": "BackgroundMode",
      "label": "background mode",
      "policies": [
        "BackgroundModeEnabled"
      ],
      "reason": "Stop Brave from running background apps after the last window closes."
    },
    {
      "id": "Promotions",
      "label": "promotional surfaces",
      "policies": [
        "PromotionsEnabled"
      ],
      "reason": "Disable promotional surfaces."
    },
    {
      "id": "BrowserLabs",
      "label": "Browser Labs",
      "policies": [
        "BrowserLabsEnabled"
      ],
      "reason": "Hide experimental Browser Labs entry points."
    },
    {
      "id": "MediaRecommendations",
      "label": "media recommendations",
      "policies": [
        "MediaRecommendationsEnabled"
      ],
      "reason": "Disable media recommendation surfaces."
    },
    {
      "id": "NewTabCards",
      "label": "new tab cards",
      "policies": [
        "NTPCardsVisible"
      ],
      "reason": "Hide new tab cards."
    },
    {
      "id": "ShoppingList",
      "label": "shopping and price tracking",
      "policies": [
        "ShoppingListEnabled"
      ],
      "reason": "Disable shopping list and price tracking surfaces."
    },
    {
      "id": "QRCodeGenerator",
      "label": "QR code generator",
      "policies": [
        "QRCodeGeneratorEnabled"
      ],
      "reason": "Disable QR code generator entry points."
    },
    {
      "id": "PaymentQueries",
      "label": "payment method queries",
      "policies": [
        "PaymentMethodQueryEnabled"
      ],
      "reason": "Prevent sites from querying stored payment method availability."
    },
    {
      "id": "Autofill",
      "label": "address and card autofill",
      "policies": [
        "AutofillCreditCardEnabled",
        "AutofillAddressEnabled"
      ],
      "reason": "Disable address and credit card autofill."
    },
    {
      "id": "Translate",
      "label": "translate prompts",
      "policies": [
        "TranslateEnabled",
        "LiveTranslateEnabled"
      ],
      "reason": "Disable page and live translate prompts."
    },
    {
      "id": "GoogleSearchSidePanel",
      "label": "Google search side panel",
      "policies": [
        "GoogleSearchSidePanelEnabled"
      ],
      "reason": "Disable the Google search side panel."
    },
    {
      "id": "NewTabBackgrounds",
      "label": "new tab background images",
      "policies": [],
      "defaultPresets": [
        "Standard",
        "High",
        "Extreme",
        "Core",
        "Privacy",
        "Aggressive"
      ],
      "reason": "Hide sponsored and background images stored in profile preferences."
    }
  ],
  "policies": {
    "BraveRewardsDisabled": {
      "type": "DWord",
      "value": 1,
      "category": "Brave feature",
      "reason": "Disable Brave Rewards, BAT prompts, and opt-in rewards ads."
    },
    "BraveWalletDisabled": {
      "type": "DWord",
      "value": 1,
      "category": "Brave feature",
      "reason": "Disable built-in crypto wallet, Web3 entry points, and decentralized DNS UI."
    },
    "BraveVPNDisabled": {
      "type": "DWord",
      "value": 1,
      "category": "Brave feature",
      "reason": "Remove Brave VPN buttons and subscription prompts."
    },
    "BraveAIChatEnabled": {
      "type": "DWord",
      "value": 0,
      "category": "Brave feature",
      "reason": "Disable Leo AI chat integrations."
    },
    "BraveNewsDisabled": {
      "type": "DWord",
      "value": 1,
      "category": "New tab",
      "reason": "Remove Brave News from the new tab experience."
    },
    "BraveTalkDisabled": {
      "type": "DWord",
      "value": 1,
      "category": "Brave feature",
      "reason": "Remove Brave Talk widgets and meeting entry points."
    },
