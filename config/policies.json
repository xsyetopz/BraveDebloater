    },
    "DefaultBraveFingerprintingV2Setting": {
      "type": "DWord",
      "value": 3,
      "category": "Shield baseline",
      "reason": "Enforce standard fingerprinting protection."
    },
    "DefaultBraveHttpsUpgradeSetting": {
      "type": "DWord",
      "value": 3,
      "category": "Shield baseline",
      "reason": "Prefer HTTPS upgrades by default."
    },
    "DefaultBraveReferrersSetting": {
      "type": "DWord",
